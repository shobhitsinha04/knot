# Files excluded from the packaged .vsix (the bundled dist/extension.js is all
# the runtime needs). Keeps the published extension small.
.vscode/**
.claude/**
.github/**
src/**
test/**
docs/**
*.vsix
# Exclude node_modules EXCEPT the LanceDB native binary + its runtime dep:
# @lancedb/lancedb is marked external in esbuild (a platform-specific .node that
# can't be bundled), so it must ship in the .vsix or the extension fails to load.
# Everything else (marked, highlight.js, katex, ignore, proper-lockfile) is
# bundled into dist / media by esbuild and stays excluded.
node_modules/**
!node_modules/@lancedb/**
!node_modules/reflect-metadata/**
**/*.ts
**/*.map
esbuild.js
eslint.config.mjs
vitest.config.ts
tsconfig*.json
.prettierrc.json
.prettierignore
.gitignore
.eslintcache
